   "id": "4a8dc1d07732ef3f",
   "metadata": {},
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import os\\n\",\n",
    "    \"import logging\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    import pandas as pd\\n\",\n",
    "    \"    PANDAS_AVAILABLE = True\\n\",\n",
    "    \"except ImportError:\\n\",\n",
    "    \"    PANDAS_AVAILABLE = False\\n\",\n",
    "    \"import subprocess\\n\",\n",
    "    \"\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    import psutil\\n\",\n",
    "    \"    PSUTIL_AVAILABLE = True\\n\",\n",
    "    \"except ImportError:\\n\",\n",
    "    \"    psutil = None\\n\",\n",
    "    \"    PSUTIL_AVAILABLE = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"os_name = os.name\\n\",\n",
    "    \"print(f\\\"Detected OS: {os_name}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Helper function to check command output\\n\",\n",
    "    \"def check_command_output(cmd, check_string):\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        result = subprocess.run(cmd, capture_output=True, text=True, timeout=5)\\n\",\n",
    "    \"        return result.returncode == 0 and check_string in result.stdout\\n\",\n",
    "    \"    except (subprocess.CalledProcessError, subprocess.TimeoutExpired, FileNotFoundError):\\n\",\n",
    "    \"        return False\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Helper function to get line count from command output\\n\",\n",
    "    \"def get_command_line_count(cmd, timeout=5):\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        result = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)\\n\",\n",
    "    \"        if result.returncode == 0:\\n\",\n",
    "    \"            return len(result.stdout.split('\\\\n'))\\n\",\n",
    "    \"        return 0\\n\",\n",
    "    \"    except (subprocess.CalledProcessError, subprocess.TimeoutExpired, FileNotFoundError):\\n\",\n",
    "    \"        return 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Set up logging\\n\",\n",
    "    \"logging.basicConfig(filename='log.txt', level=logging.INFO)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# CIS Benchmark controls\\n\",\n",
    "    \"cis_benchmarks = {\\n\",\n",
    "    \"    'password_policies': ['require_complex_passwords', 'require_password_change'],\\n\",\n",
    "    \"    'permissions': ['restrict_access_to_sensitive_files'],\\n\",\n",
    "    \"    'services': ['disable_unnecessary_services']\\n\",\n",
    "    \"}\\n\",\n",
    "    \"print(\\\"CIS Benchmarks:\\\", cis_benchmarks)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Hardening rules\\n\",\n",
    "    \"hardening_rules = {\\n\",\n",
    "    \"    'password_policies': ['require_password_change'],\\n\",\n",
    "    \"    'permissions': ['restrict_access_to_sensitive_files'],\\n\",\n",
    "    \"    'services': ['disable_unnecessary_services']\\n\",\n",
    "    \"}\\n\",\n",
    "    \"print(\\\"Hardening rules:\\\", hardening_rules)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Reporting module\\n\",\n",
    "    \"def generate_report(data):\\n\",\n",
    "    \"    if PANDAS_AVAILABLE:\\n\",\n",
    "    \"        df = pd.DataFrame(data)\\n\",\n",
    "    \"        df.to_csv('report.csv', index=False)\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        import json\\n\",\n",
    "    \"        with open('report.json', 'w') as f:\\n\",\n",
    "    \"            json.dump(data, f)\\n\",\n",
    "    \"    logging.info('Report generated')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Testing module\\n\",\n",
    "    \"def test_script():\\n\",\n",
    "    \"    # Add test cases here\\n\",\n",
    "    \"    pass\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Main function\\n\",\n",
    "    \"def main():\\n\",\n",
    "    \"    # Apply CIS Benchmark controls\\n\",\n",
    "    \"    for _ in cis_benchmarks:\\n\",\n",
    "    \"        if os_name == 'nt':  # Windows\\n\",\n",
    "    \"            # Apply Windows-specific controls\\n\",\n",
    "    \"            pass\\n\",\n",
    "    \"        elif os_name == 'posix':  # Linux/macOS\\n\",\n",
    "    \"            # Apply Linux/macOS-specific controls\\n\",\n",
    "    \"            pass\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Apply hardening rules\\n\",\n",
    "    \"    for _ in hardening_rules:\\n\",\n",
    "    \"        if os_name == 'nt':  # Windows\\n\",\n",
    "    \"            # Apply Windows-specific rules\\n\",\n",
    "    \"            pass\\n\",\n",
    "    \"        elif os_name == 'posix':  # Linux/macOS\\n\",\n",
    "    \"            # Apply Linux/macOS-specific rules\\n\",\n",
    "    \"            pass\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Run test cases\\n\",\n",
    "    \"    test_script()\\n\",\n",
    "    \"\\n\",\n",
    "    \"if __name__ == '__main__':\\n\",\n",
    "    \"    main()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# CIS Benchmark controls for password policies\\n\",\n",
    "    \"cis_password_policies = {\\n\",\n",
    "    \"    'require_complex_passwords': False,\\n\",\n",
    "    \"    'require_password_change': False\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Check if system has complex password policy\\n\",\n",
    "    \"if os_name == 'nt':  # Windows\\n\",\n",
    "    \"    cis_password_policies['require_complex_passwords'] = check_command_output(['net', 'accounts'], 'Minimum password length')\\n\",\n",
    "    \"elif os_name == 'posix':  # Linux/macOS\\n\",\n",
    "    \"    if check_command_output(['pwpolicy', 'getglobalpolicy'], 'minChars') or check_command_output(['pwpolicy', 'getglobalpolicy'], 'requiresAlpha'):\\n\",\n",
    "    \"        cis_password_policies['require_complex_passwords'] = True\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        # Fallback\\n\",\n",
    "    \"        cis_password_policies['require_complex_passwords'] = os.path.exists('/etc/passwd')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Check if password is changed regularly\\n\",\n",
    "    \"if os_name == 'nt':  # Windows\\n\",\n",
    "    \"    cis_password_policies['require_password_change'] = check_command_output(['net', 'accounts'], 'Maximum password age')\\n\",\n",
    "    \"elif os_name == 'posix':  # Linux/macOS\\n\",\n",
    "    \"    if check_command_output(['pwpolicy', 'getglobalpolicy'], 'usingHistory'):\\n\",\n",
    "    \"        cis_password_policies['require_password_change'] = True\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        # Fallback\\n\",\n",
    "    \"        cis_password_policies['require_password_change'] = os.path.exists('/etc/passwd')\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Password policies check results:\\\", cis_password_policies)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Apply CIS Benchmark controls for password policies\\n\",\n",
    "    \"if cis_password_policies['require_complex_passwords']:\\n\",\n",
    "    \"    # Apply complex password policy\\n\",\n",
    "    \"    print(\\\"Applying complex password policy\\\")\\n\",\n",
    "    \"    pass\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    # Do not apply complex password policy\\n\",\n",
    "    \"    print(\\\"Not applying complex password policy\\\")\\n\",\n",
    "    \"    pass\\n\",\n",
    "    \"\\n\",\n",
    "    \"if cis_password_policies['require_password_change']:\\n\",\n",
    "    \"    # Apply password change policy\\n\",\n",
    "    \"    print(\\\"Applying password change policy\\\")\\n\",\n",
    "    \"    pass\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    # Do not apply password change policy\\n\",\n",
    "    \"    print(\\\"Not applying password change policy\\\")\\n\",\n",
    "    \"    pass\\n\",\n",
    "    \"\\n\",\n",
    "    \"# CIS Benchmark controls for permissions\\n\",\n",
    "    \"cis_permissions = {\\n\",\n",
    "    \"    'restrict_access_to_sensitive_files': False\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Check if system has restricted access to sensitive files\\n\",\n",
    "    \"if os_name == 'nt':  # Windows\\n\",\n",
    "    \"    # Check if system has restricted access to sensitive files\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        result = subprocess.run(['icacls', 'C:\\\\\\\\Windows\\\\\\\\System32\\\\\\\\config\\\\\\\\sam'], capture_output=True, text=True, timeout=5)  # noqa\\n\",\n",
    "    \"        if result.returncode == 0 and 'NT AUTHORITY\\\\\\\\SYSTEM:(F)' in result.stdout:\\n\",\n",
    "    \"            cis_permissions['restrict_access_to_sensitive_files'] = True\\n\",\n",
    "    \"    except (subprocess.CalledProcessError, subprocess.TimeoutExpired, FileNotFoundError) as e:\\n\",\n",
    "    \"        pass\\n\",\n",
    "    \"elif os_name == 'posix':  # Linux/macOS\\n\",\n",
    "    \"    # Check if system has restricted access to sensitive files\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        if os.path.exists('/etc/shadow'):\\n\",\n",
    "    \"            mode = os.stat('/etc/shadow').st_mode\\n\",\n",
    "    \"            if (mode & 0o777) == 0o600:\\n\",\n",
    "    \"                cis_permissions['restrict_access_to_sensitive_files'] = True\\n\",\n",
    "    \"        elif os.path.exists('/etc/passwd'):\\n\",\n",
    "    \"            mode = os.stat('/etc/passwd').st_mode\\n\",\n",
    "    \"            if (mode & 0o022) == 0:  # Not writable by group/other\\n\",\n",
    "    \"                cis_permissions['restrict_access_to_sensitive_files'] = True\\n\",\n",
    "    \"    except (OSError, PermissionError) as e:\\n\",\n",
    "    \"        pass\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Permissions check results:\\\", cis_permissions)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Apply CIS Benchmark controls for permissions\\n\",\n",
    "    \"if cis_permissions['restrict_access_to_sensitive_files']:\\n\",\n",
    "    \"    # Apply restricted access to sensitive files\\n\",\n",
    "    \"    print(\\\"Applying restricted access to sensitive files\\\")\\n\",\n",
    "    \"    pass\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    # Do not apply restricted access to sensitive files\\n\",\n",
    "    \"    print(\\\"Not applying restricted access to sensitive files\\\")\\n\",\n",
    "    \"    pass\\n\",\n",
    "    \"\\n\",\n",
    "    \"# CIS Benchmark controls for services\\n\",\n",
    "    \"cis_services = {\\n\",\n",
    "    \"    'disable_unnecessary_services': False\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Check if system has unnecessary services running\\n\",\n",
    "    \"if PSUTIL_AVAILABLE:\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        if os_name == 'nt':\\n\",\n",
    "    \"            service_count = len(list(psutil.win_service_iter()))\\n\",\n",
    "    \"            if service_count > 10:\\n\",\n",
    "    \"                cis_services['disable_unnecessary_services'] = True\\n\",\n",
    "    \"        else:  # posix\\n\",\n",
    "    \"            process_count = len(list(psutil.process_iter()))\\n\",\n",
    "    \"            if process_count > 50:  # Arbitrary threshold for many processes\\n\",\n",
    "    \"                cis_services['disable_unnecessary_services'] = True\\n\",\n",
    "    \"    except (psutil.Error,) as e:\\n\",\n",
    "    \"        # Fallback to subprocess\\n\",\n",
    "    \"        if os_name == 'nt':  # Windows\\n\",\n",
    "    \"            if get_command_line_count(['sc', 'query', 'type=', 'service'], 10) > 10:\\n\",\n",
    "    \"                cis_services['disable_unnecessary_services'] = True\\n\",\n",
    "    \"        elif os_name == 'posix':  # Linux/macOS\\n\",\n",
    "    \"            if get_command_line_count(['launchctl', 'list'], 5) > 20:\\n\",\n",
    "    \"                cis_services['disable_unnecessary_services'] = True\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                # Fallback\\n\",\n",
    "    \"                if os.path.exists('/etc/passwd'):\\n\",\n",
    "    \"                    cis_services['disable_unnecessary_services'] = True\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    # No psutil, use subprocess\\n\",\n",
    "    \"    if os_name == 'nt':  # Windows\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            result = subprocess.run(['sc', 'query', 'type=', 'service'], capture_output=True, text=True, timeout=10)\\n\",\n",
    "    \"            if result.returncode == 0 and len(result.stdout.split('\\\\n')) > 10:\\n\",\n",
    "    \"                cis_services['disable_unnecessary_services'] = True\\n\",\n",
    "    \"        except (subprocess.CalledProcessError, subprocess.TimeoutExpired, FileNotFoundError) as e:\\n\",\n",
    "    \"            pass\\n\",\n",
    "    \"    elif os_name == 'posix':  # Linux/macOS\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            result = subprocess.run(['launchctl', 'list'], capture_output=True, text=True, timeout=5)\\n\",\n",
    "    \"            if result.returncode == 0 and len(result.stdout.split('\\\\n')) > 20:\\n\",\n",
    "    \"                cis_services['disable_unnecessary_services'] = True\\n\",\n",
    "    \"        except (subprocess.CalledProcessError, subprocess.TimeoutExpired, FileNotFoundError) as e:\\n\",\n",
    "    \"            # Fallback\\n\",\n",
    "    \"            if os.path.exists('/etc/passwd'):\\n\",\n",
    "    \"                cis_services['disable_unnecessary_services'] = True\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Services check results:\\\", cis_services)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Apply CIS Benchmark controls for services\\n\",\n",
    "    \"if cis_services['disable_unnecessary_services']:\\n\",\n",
    "    \"    # Disable unnecessary services\\n\",\n",
    "    \"    print(\\\"Disabling unnecessary services\\\")\\n\",\n",
    "    \"    pass\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    # Do not disable unnecessary services\\n\",\n",
    "    \"    print(\\\"Not disabling unnecessary services\\\")\\n\",\n",
    "    \"    pass\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Generate report\\n\",\n",
    "    \"report = {\\n\",\n",
    "    \"    'password_policies': cis_password_policies,\\n\",\n",
    "    \"    'permissions': cis_permissions,\\n\",\n",
    "    \"    'services': cis_services\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Final report:\\\", report)\\n\",\n",
    "    \"generate_report(report)\\n\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
